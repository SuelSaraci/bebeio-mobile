# API (local dev — use your machine IP on physical devices)
EXPO_PUBLIC_API_URL=http://localhost:5002
# Production (set on EAS for App Store builds, not in local .env):
# EXPO_PUBLIC_API_URL=https://bebeio-server-production.up.railway.app

# Website used for Bebio Plus checkout (no in-app purchases)
# Production: https://bebeio-web-production.up.railway.app
EXPO_PUBLIC_WEB_URL=http://localhost:5173

# Preview production iOS App Store UI in the iOS simulator (optional)
# EXPO_PUBLIC_PREVIEW_IOS_APP_STORE_UI=true

# Firebase (same project as API server)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=bebeio.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=bebeio
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=bebeio.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# EAS (Expo cloud builds + push notifications)
EXPO_PUBLIC_EAS_PROJECT_ID=a54d29e2-d0db-4da0-907a-83dcdea7fb32

# Legal URLs (shown in app)
EXPO_PUBLIC_TERMS_URL=https://bebeio.com/terms
EXPO_PUBLIC_PRIVACY_URL=https://bebeio.com/privacy
